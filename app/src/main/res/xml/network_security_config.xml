<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Disallow cleartext traffic to all domains (HTTPS only) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust the system CA store (production certificates) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- In debug builds, also trust user-installed CAs (for Charles/mitmproxy) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
